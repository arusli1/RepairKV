digraph IdleKV {
  graph [
    rankdir=LR,
    pad="0.2",
    nodesep="0.55",
    ranksep="0.95",
    splines=spline,
    bgcolor="white",
    fontname="Helvetica"
  ];

  node [
    shape=box,
    style="rounded,filled",
    margin="0.18,0.14",
    fontname="Helvetica",
    fontsize=20,
    penwidth=2.2
  ];

  edge [
    fontname="Helvetica",
    fontsize=13,
    arrowsize=0.85,
    penwidth=2.1,
    color="#111827",
    fontcolor="#374151"
  ];

  current_gpu [
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
        <TR><TD><B>Active GPU KV cache</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="15">current turn <I>t</I></FONT></TD></TR>
      </TABLE>
    >,
    fillcolor="#E8F0FF",
    color="#2563EB"
  ];

  next_gpu [
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
        <TR><TD><B>Restored GPU KV cache</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="15">next turn <I>t</I> + 1</FONT></TD></TR>
      </TABLE>
    >,
    fillcolor="#E8F0FF",
    color="#2563EB"
  ];

  subgraph cluster_idle {
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLPADDING="2">
        <TR><TD><B>Tool-call idle window</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="14">foreground decode pauses while the tool runs</FONT></TD></TR>
      </TABLE>
    >;
    labelloc="t";
    fontsize=22;
    fontname="Helvetica";
    penwidth=1.8;
    color="#CBD5E1";
    style="rounded,filled";
    fillcolor="#F8FAFC";
    margin=22;

    idle_note [
      shape=plain,
      label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLPADDING="2">
          <TR><TD><FONT POINT-SIZE="14">background repair work stays inside the same wall-clock window</FONT></TD></TR>
        </TABLE>
      >
    ];

    cpu_buffer [
      label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
          <TR><TD><B>CPU eviction buffer</B></TD></TR>
          <TR><TD><FONT POINT-SIZE="15">evicted KV pairs</FONT></TD></TR>
          <TR><TD><FONT POINT-SIZE="15">plus original positions</FONT></TD></TR>
        </TABLE>
      >,
      fillcolor="#FFF4E8",
      color="#EA580C"
    ];

    scorer [
      label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
          <TR><TD><B>Score and select</B></TD></TR>
          <TR><TD><FONT POINT-SIZE="15">recent queries rank</FONT></TD></TR>
          <TR><TD><FONT POINT-SIZE="15">buffered entries</FONT></TD></TR>
        </TABLE>
      >,
      fillcolor="#ECFEFF",
      color="#0891B2"
    ];

    idle_note -> cpu_buffer [style=invis, weight=8];
    idle_note -> scorer [style=invis, weight=8];
    cpu_buffer -> scorer [
      color="#0891B2",
      fontcolor="#0F766E",
      penwidth=2.4,
      label="score buffered KV against recent queries"
    ];
  }

  current_gpu -> idle_note [label="tool call begins", minlen=2];
  current_gpu -> cpu_buffer [
    color="#EA580C",
    fontcolor="#C2410C",
    style=dashed,
    penwidth=2.4,
    label="evict dropped tokens to host memory",
    minlen=2
  ];
  scorer -> next_gpu [
    color="#2563EB",
    fontcolor="#1D4ED8",
    penwidth=2.4,
    label="restore top-K before the next turn",
    minlen=2
  ];
  idle_note -> next_gpu [label="tool result returns", minlen=2];
}
